# Example environment configuration for nvx-based apps
# Copy to .env and adjust values for your environment.

APP_NAME=nvx
APP_ENV=development
LOG_LEVEL=info
PORT=8080

DATABASE_URL=postgres://nvx:password@localhost:5432/nvx?sslmode=disable
REDIS_URL=redis://localhost:6379/0
API_BASE_URL=https://api.example.com

# REQUIRED: API_KEY
API_KEY=

AUTH_JWT_ISSUER=https://auth.example.com
AUTH_JWT_AUDIENCE=nvx
AUTH_JWT_SECRET=dev-secret

TLS_CERT_PATH=./certs/dev.crt
TLS_KEY_PATH=./certs/dev.key

OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# Optional values
SENTRY_DSN=
FEATURE_FLAGS=
CACHE_TTL_SECONDS=300
REQUEST_TIMEOUT_SECONDS=30
PUBLIC_KEY="-----BEGIN PUBLIC KEY-----
